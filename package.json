{
  "name": "polyclaude",
  "version": "0.1.0",
  "description": "Multi-account manager, usage dashboard, and seamless session switcher for Claude Code",
  "type": "module",
  "license": "MIT",
  "author": "BeeeFX",
  "homepage": "https://github.com/BeeeFX/polyclaude#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BeeeFX/polyclaude.git"
  },
  "bugs": {
    "url": "https://github.com/BeeeFX/polyclaude/issues"
  },
  "keywords": [
    "claude",
    "claude-code",
    "cli",
    "tui",
    "account-switcher",
    "usage",
    "anthropic"
  ],
  "bin": {
    "polyclaude": "./dist/cli/index.js",
    "pcc": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "os": [
    "win32"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli/index.ts",
    "pcc": "tsx src/cli/index.ts",
    "smoke": "tsx test/tui-smoke.tsx",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "ink": "^5.2.1",
    "picocolors": "^1.1.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.31",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
