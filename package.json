{
  "name": "polyclaude",
  "version": "0.1.0",
  "description": "Multi-account manager, usage dashboard, and seamless session switcher for Claude Code",
  "type": "module",
  "license": "MIT",
  "author": "BeeeFX",
  "homepage": "https://github.com/BeeeFX/polyclaude#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BeeeFX/polyclaude.git"
  },
  "bugs": {
    "url": "https://github.com/BeeeFX/polyclaude/issues"
  },
  "keywords": [
    "claude",
    "claude-code",
    "cli",
    "tui",
    "account-switcher",
    "usage",
    "anthropic"
  ],
  "bin": {
    "polyclaude": "./dist/cli/index.js",
    "pcc": "./dist/cli/index.js"
  },
  "main": "dist/main/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:gui": "tsc -p tsconfig.json && vite build",
    "dev": "tsx src/cli/index.ts",
    "pcc": "tsx src/cli/index.ts",
    "gui": "npm run build:gui && electron .",
    "gui:dev": "tsc -p tsconfig.json && concurrently -k -n vite,electron \"vite\" \"wait-on tcp:127.0.0.1:5173 && cross-env POLY_DEV_SERVER=http://localhost:5173 electron .\"",
    "smoke": "tsx test/tui-smoke.tsx",
    "test:statusline": "tsx test/statusline-smoke.ts",
    "test:crypto": "tsx test/crypto-smoke.ts",
    "test": "npm run typecheck && npm run typecheck:gui && npm run smoke && npm run test:statusline && npm run test:crypto",
    "typecheck": "tsc --noEmit",
    "typecheck:gui": "tsc -p src/renderer/tsconfig.json",
    "prepare": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "ink": "^5.2.1",
    "picocolors": "^1.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "wait-on": "^8.0.1"
  }
}
